      <aliases enabled='yes' />
      <column caption='Postal Code_Clean' datatype='integer' name='[Calculation_0906847069491200]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL([Postal Code], 0)' />
      </column>
      <column caption='Outlier_Flag' datatype='string' name='[Calculation_0906847073370113]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Sales] &gt; 5000 THEN &quot;Outlier&quot;&#13;&#10;ELSE &quot;Normal&quot;&#13;&#10;END' />
      </column>
      <column caption='Sales_Capped' datatype='real' name='[Calculation_0906847076696071]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Sales] &gt; 5000 THEN 5000&#13;&#10;ELSE [Sales]&#13;&#10;END' />
      </column>
      <column caption='Region_Clean' datatype='string' name='[Calculation_0906847079112712]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Region] = &quot;SOUTH&quot; THEN &quot;South&quot;&#13;&#10;ELSEIF [Region] = &quot;South Region&quot; THEN &quot;South&quot;&#13;&#10;ELSE [Region]&#13;&#10;END' />
      </column>
      <column caption='Profit Ratio' datatype='real' name='[Calculation_1368249927221915648]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
